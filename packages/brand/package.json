{
  "name": "@repo/brand",
  "version": "0.1.0",
  "description": "Shared brand tokens, reusable Tailwind utility classes, and theme utilities for platform template apps.",
  "type": "module",
  "author": "Platform Template Team",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles/globals.css"
  },
  "files": ["dist", "src/styles/globals.css", "README.md"],
  "sideEffects": ["./src/styles/globals.css"],
  "scripts": {
    "build": "tsup --tsconfig tsconfig.json src/index.ts --format esm,cjs --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "check-types": "npm run typecheck",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "next": ">=16",
    "next-themes": "^0.2.1",
    "react": ">=18",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.2",
    "eslint": "^9.39.1",
    "next-themes": "^0.2.1",
    "rimraf": "^5.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
